# Databricks connection — copy this file to `.env` and fill in real values.
# `.env` is git-ignored; NEVER commit it.

# Workspace hostname (with or without https://). Example: dbc-xxxx.cloud.databricks.com
DATABRICKS_HOST=dbc-xxxxxxxx-xxxx.cloud.databricks.com

# Personal Access Token (User Settings -> Developer -> Access tokens). Starts with "dapi".
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL Warehouse HTTP path (SQL Warehouses -> your warehouse -> Connection details).
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX

# Unity Catalog target. The pipeline creates these if they don't exist.
DQ_CATALOG=people_org
DQ_SCHEMA=dq_observability
DQ_VOLUME=landing
